<!DOCTYPE html>
<html>
<head>
    <title>All Tasks</title>
    <meta http-equiv="refresh" content="10">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Syne:wght@600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-base:       #080d1a;
            --bg-surface:    #0e1628;
            --bg-card:       #111c35;
            --bg-card-hover: #152040;
            --border:        #1e2f52;
            --border-hover:  #2a4070;
            --accent:        #3b7de8;
            --accent-dim:    #1e4a9a;
            --accent-glow:   rgba(59, 125, 232, 0.18);
            --text-primary:  #e8eef8;
            --text-secondary:#8fa3c8;
            --text-muted:    #4d6490;
            --success:       #22c97a;
            --success-bg:    rgba(34, 201, 122, 0.1);
            --warning:       #f5a623;
            --warning-bg:    rgba(245, 166, 35, 0.1);
            --danger:        #e8505b;
            --danger-bg:     rgba(232, 80, 91, 0.1);
            --blue-bg:       rgba(59, 125, 232, 0.1);
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            background-color: var(--bg-base);
            color: var(--text-primary);
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            min-height: 100vh;
        }

        /* subtle grid texture on bg */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(var(--border) 1px, transparent 1px),
                linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 40px 40px;
            opacity: 0.18;
            pointer-events: none;
            z-index: 0;
        }

        .container { position: relative; z-index: 1; max-width: 780px; }

        /* ── Header ── */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 2.5rem 0 1.75rem;
            border-bottom: 1px solid var(--border);
            margin-bottom: 2rem;
        }

        .page-header h1 {
            font-family: 'Syne', sans-serif;
            font-size: 1.75rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: var(--text-primary);
            margin: 0;
        }

        .page-header h1 span {
            color: var(--accent);
        }

        /* ── Buttons ── */
        .btn-primary-custom {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--accent);
            color: #fff;
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 500;
            padding: 9px 20px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.18s, box-shadow 0.18s, transform 0.12s;
            box-shadow: 0 0 0 0 var(--accent-glow);
        }
        .btn-primary-custom:hover {
            background: #4d8ef0;
            box-shadow: 0 0 16px var(--accent-glow);
            transform: translateY(-1px);
            color: #fff;
            text-decoration: none;
        }
        .btn-primary-custom:active { transform: scale(0.97); }

        .btn-action {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 500;
            padding: 7px 16px;
            border-radius: 7px;
            border: 1px solid;
            cursor: pointer;
            transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
        }
        .btn-action:active { transform: scale(0.97); }

        .btn-claim {
            background: var(--blue-bg);
            color: var(--accent);
            border-color: var(--accent-dim);
        }
        .btn-claim:hover {
            background: rgba(59, 125, 232, 0.2);
            box-shadow: 0 0 10px var(--accent-glow);
        }

        .btn-complete {
            background: var(--warning-bg);
            color: var(--warning);
            border-color: rgba(245, 166, 35, 0.35);
        }
        .btn-complete:hover {
            background: rgba(245, 166, 35, 0.18);
            box-shadow: 0 0 10px rgba(245, 166, 35, 0.15);
        }

        /* ── Task Card ── */
        .task-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.25rem 1.4rem;
            margin-bottom: 1rem;
            transition: border-color 0.2s, background 0.2s, transform 0.15s;
        }
        .task-card:hover {
            background: var(--bg-card-hover);
            border-color: var(--border-hover);
            transform: translateY(-1px);
        }

        .task-card-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 0.6rem;
        }

        .task-title {
            font-family: 'Syne', sans-serif;
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--text-primary);
            margin: 0;
        }

        .task-bounty {
            font-family: 'DM Sans', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            color: var(--success);
            white-space: nowrap;
            background: var(--success-bg);
            padding: 3px 10px;
            border-radius: 6px;
        }

        .task-desc {
            color: var(--text-secondary);
            font-size: 14px;
            margin: 0 0 1rem;
            line-height: 1.6;
        }

        /* ── Meta row ── */
        .task-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
            margin-bottom: 1rem;
        }

        .meta-chip {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            color: var(--text-muted);
            background: var(--bg-surface);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 4px 10px;
        }
        .meta-chip strong {
            color: var(--text-secondary);
            font-weight: 500;
        }

        /* ── Status Badge ── */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            font-weight: 500;
            padding: 4px 10px;
            border-radius: 20px;
        }
        .status-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            display: inline-block;
        }
        .status-open {
            background: var(--blue-bg);
            color: var(--accent);
            border: 1px solid var(--accent-dim);
        }
        .status-open::before { background: var(--accent); }

        .status-claimed {
            background: var(--warning-bg);
            color: var(--warning);
            border: 1px solid rgba(245,166,35,0.3);
        }
        .status-claimed::before { background: var(--warning); }

        .status-completed {
            background: var(--success-bg);
            color: var(--success);
            border: 1px solid rgba(34,201,122,0.3);
        }
        .status-completed::before { background: var(--success); }

        /* ── Contact Info ── */
        .contact-box {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--success-bg);
            border: 1px solid rgba(34,201,122,0.25);
            border-radius: 7px;
            padding: 7px 12px;
            font-size: 13px;
            color: var(--success);
            margin-bottom: 10px;
        }

        /* ── Done Tag ── */
        .done-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--text-muted);
            font-size: 13px;
        }

        /* ── Actions row ── */
        .task-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        /* remove bootstrap defaults on forms inside cards */
        .task-card form { margin: 0; }
    </style>
</head>

<body>
<div class="container mt-0 pb-5">

    <div class="page-header">
        <h1>All <span>Tasks</span></h1>
        <a href="/tasks/new" class="btn-primary-custom">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            New Task
        </a>
    </div>

    <% tasks.forEach(task => { %>

        <div class="task-card">

            <div class="task-card-top">
                <h5 class="task-title"><%= task.title %></h5>
                <span class="task-bounty">₹<%= task.bounty %></span>
            </div>

            <p class="task-desc"><%= task.description %></p>

            <div class="task-meta">
                <%
                    let statusClass = 'status-open';
                    if (task.status === 'Claimed')   statusClass = 'status-claimed';
                    if (task.status === 'Completed') statusClass = 'status-completed';
                %>
                <span class="status-badge <%= statusClass %>"><%= task.status %></span>

                <span class="meta-chip">
                    <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="4" r="2.5" stroke="currentColor" stroke-width="1.3"/><path d="M1.5 10.5c0-2.485 2.015-4.5 4.5-4.5s4.5 2.015 4.5 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    <strong>By:</strong> <%= task.requester?.username || "Unknown" %>
                </span>

                <span class="meta-chip">
                    <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M6 1l1.3 2.6 2.9.4-2.1 2 .5 2.9L6 7.6 3.4 9l.5-2.9L1.8 4l2.9-.4z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/></svg>
                    <strong>Tasker:</strong> <%= task.tasker?.username || "Not assigned" %>
                </span>
            </div>

            <div class="task-actions">

                <% if (task.status === 'Open') { %>
                    <% if (task.requester && task.requester._id.toString() !== userId?.toString()) { %>
                        <form action="/tasks/<%= task._id %>/claim" method="POST">
                            <button class="btn-action btn-claim" type="submit">
                                <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Claim Task
                            </button>
                        </form>
                    <% } %>
                <% } else if (task.status === 'Claimed' || task.status === 'Completed') { %>

                    <% if (
                        task.requester && task.tasker && userId &&
                        task.requester._id.toString() === userId.toString()
                    ) { %>
                        <div class="contact-box">
                            <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 2h4l1.5 3.5-2 1.2a7.5 7.5 0 003.8 3.8l1.2-2L14 10v4a2 2 0 01-2 0C5.37 13.5.5 8.63.5 2a2 2 0 010-2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
                            <%= task.tasker.phone || "No phone available" %>
                        </div>
                    <% } %>

                    <% if (
                        task.status === 'Claimed' &&
                        task.tasker && userId &&
                        task.tasker._id.toString() === userId.toString()
                    ) { %>
                        <form action="/tasks/<%= task._id %>/complete" method="POST">
                            <button class="btn-action btn-complete" type="submit">
                                <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Mark Complete
                            </button>
                        </form>
                    <% } %>

                    <% if (task.status === 'Completed') { %>
                        <span class="done-tag">
                            <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="#22c97a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            Completed
                        </span>
                    <% } %>

                <% } %>

            </div>
        </div>

    <% }) %>

</div>
</body>
</html>
